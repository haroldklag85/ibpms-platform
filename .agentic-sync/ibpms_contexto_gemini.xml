<file path="backend/ibpms-core/src/main/resources/db/changelog/001-initial-schema.xml">
<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="ibpms-core-team">
        <comment>Estructura inicial del core alineada al ERD (Hexagonal Core, agnóstica de Camunda Act_* tables)</comment>

        <!-- 1. Catálogos Base -->
        <createTable tableName="sys_catalog">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="sys_catalog_item">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="catalog_id" type="VARCHAR(50)">
                <constraints nullable="false" foreignKeyName="fk_catalog_item_parent" referencedTableName="sys_catalog" referencedColumnNames="id"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- 2. Casos / Expedientes -->
        <createTable tableName="ibpms_case">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="definition_key" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="business_key" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="JSON"/>
            <column name="process_instance_id" type="CHAR(36)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <!-- Índice para optimizar búsquedas por radicado visible -->
        <createIndex tableName="ibpms_case" indexName="idx_ibpms_case_business_key">
            <column name="business_key"/>
        </createIndex>

        <!-- 3. Tareas (Replica la metadata local sin amarrar FK directo a ACT_*) -->
        <createTable tableName="ibpms_task">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_id" type="CHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_ibpms_task_case" referencedTableName="ibpms_case" referencedColumnNames="id"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="definition_key" type="VARCHAR(100)"/>
            <column name="source_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="ref_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="assignee" type="VARCHAR(100)"/>
            <column name="candidate_groups" type="JSON"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="INT"/>
            <column name="due_date" type="TIMESTAMP"/>
            <column name="camunda_task_id" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
        </createTable>

        <!-- 4. Documentos Legales (SGDEA apuntando a Azure Blob) -->
        <createTable tableName="ibpms_document">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_id" type="CHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_ibpms_document_case" referencedTableName="ibpms_case" referencedColumnNames="id"/>
            </column>
            <column name="document_type_code" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="blob_uri" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="sha256_hash" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="uploaded_by" type="VARCHAR(100)"/>
            <column name="uploaded_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="retention_end_date" type="TIMESTAMP"/>
        </createTable>

        <!-- 5. Metadata Index (Performance sobre JSON) -->
        <createTable tableName="ibpms_metadata_index">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="case_id" type="CHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_metadata_index_case" referencedTableName="ibpms_case" referencedColumnNames="id"/>
            </column>
            <column name="search_key" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="search_value_string" type="VARCHAR(255)"/>
            <column name="search_value_number" type="DECIMAL(19,4)"/>
        </createTable>

        <createIndex tableName="ibpms_metadata_index" indexName="idx_metadata_search">
            <column name="search_key"/>
            <column name="search_value_string"/>
        </createIndex>

        <!-- 6. Idempotency Key (Operaciones POST) -->
        <createTable tableName="ibpms_idempotency_key">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="response_payload" type="JSON"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- 7. Audit Log -->
        <createTable tableName="ibpms_audit_log">
            <column name="id" type="CHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="performed_by" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="event_data" type="JSON"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
</file>

