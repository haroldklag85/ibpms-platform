    <script>
        function startProcess(processName) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = `Se ha instanciado un nuevo caso para '${processName}'.`;
            
            toast.classList.remove('translate-y-20', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
                
                // Redirect to inbox after starting
                if (confirm(`¿Ir a la bandeja unificada para ver el nuevo caso de ${processName}?`)) {
                    window.location.href = 'inbox.html';
                }
            }, 3000);
        }
    </script>
