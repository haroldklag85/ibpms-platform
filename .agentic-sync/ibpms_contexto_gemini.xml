                    </ul>
                </div>

                <!-- Bottlenecks -->
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm relative overflow-hidden">
                    <div
                        class="absolute top-0 right-0 w-32 h-32 bg-red-100 rounded-full blur-3xl -mr-10 -mt-10 z-0 opacity-50">
                    </div>

                    <h3
                        class="text-sm font-bold text-gray-700 uppercase tracking-wider mb-4 border-b pb-2 relative z-10">
