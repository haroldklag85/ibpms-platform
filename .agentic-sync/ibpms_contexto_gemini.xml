spring:
  application:
    name: ibpms-core
  datasource:
    url: jdbc:mysql://${MYSQL_HOST:localhost}:${MYSQL_PORT:3306}/${MYSQL_DATABASE:ibpms}?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
