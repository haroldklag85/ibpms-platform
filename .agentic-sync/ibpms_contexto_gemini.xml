                        <!-- Card 1 -->
                        <div class="bg-white border border-indigo-100 rounded-lg p-3 shadow-sm relative group"
                            x-data="{ accepted: false }">
                            <p class="text-xs text-gray-500 mb-1">Clasificación</p>
                            <p class="text-sm font-bold text-gray-900" :class="accepted ? 'text-green-600' : ''">Informe
                                Financiero / Legal</p>
                            <div class="mt-3 flex space-x-2" x-show="!accepted">
                                <button @click="accepted = true"
                                    class="flex-1 text-xs bg-indigo-50 text-indigo-700 hover:bg-indigo-100 py-1 rounded border border-indigo-200 transition-colors"><i
                                        class="fa-solid fa-check mr-1"></i> Aceptar</button>
                                <button
                                    class="flex-1 text-xs bg-gray-50 text-gray-600 hover:bg-gray-100 py-1 rounded border border-gray-200 transition-colors"><i
                                        class="fa-solid fa-xmark mr-1"></i> Rechazar</button>
                            </div>
                            <div x-show="accepted" class="mt-2 text-xs text-green-600 font-medium"><i
                                    class="fa-solid fa-circle-check"></i> Metadato Guardado</div>
                        </div>

                        <!-- Card 2 -->
                        <div class="bg-white border border-indigo-100 rounded-lg p-3 shadow-sm"
                            x-data="{ accepted: false }">
                            <p class="text-xs text-gray-500 mb-1">Cliente Asociado</p>
                            <p class="text-sm font-bold text-gray-900" :class="accepted ? 'text-green-600' : ''">Client
                                Corp (CRM ID: 9481)</p>
                            <div class="mt-3 flex space-x-2" x-show="!accepted">
                                <button @click="accepted = true"
                                    class="flex-1 text-xs bg-indigo-50 text-indigo-700 hover:bg-indigo-100 py-1 rounded border border-indigo-200 transition-colors"><i
                                        class="fa-solid fa-check mr-1"></i> Aceptar</button>
                                <button
                                    class="flex-1 text-xs bg-gray-50 text-gray-600 hover:bg-gray-100 py-1 rounded border border-gray-200 transition-colors"><i
                                        class="fa-solid fa-xmark mr-1"></i> Rechazar</button>
                            </div>
                            <div x-show="accepted" class="mt-2 text-xs text-green-600 font-medium"><i
                                    class="fa-solid fa-circle-check"></i> Vinculado al Cliente</div>
                        </div>

                        <!-- Card 3 -->
                        <div class="bg-white border border-indigo-100 rounded-lg p-3 shadow-sm"
                            x-data="{ accepted: false }">
                            <p class="text-xs text-gray-500 mb-1">Fecha Límite (Deadline)</p>
                            <p class="text-sm font-bold text-gray-900" :class="accepted ? 'text-green-600' : ''"><i
                                    class="fa-regular fa-calendar-check text-red-500 mr-1"></i> 28 Octubre, 2024</p>
                            <div class="mt-3 flex space-x-2" x-show="!accepted">
                                <button @click="accepted = true"
                                    class="flex-1 text-xs bg-indigo-50 text-indigo-700 hover:bg-indigo-100 py-1 rounded border border-indigo-200 transition-colors"><i
                                        class="fa-solid fa-check mr-1"></i> Aceptar</button>
                                <button
                                    class="flex-1 text-xs bg-gray-50 text-gray-600 hover:bg-gray-100 py-1 rounded border border-gray-200 transition-colors"><i
                                        class="fa-solid fa-xmark mr-1"></i> Rechazar</button>
                            </div>
                            <div x-show="accepted" class="mt-2 text-xs text-green-600 font-medium"><i
                                    class="fa-solid fa-circle-check"></i> Fecha Guardada</div>
                        </div>

                    </div>
                </div>

                <!-- Tareas Sugeridas -->
                <div class="flex space-x-6">

                    <!-- Integracion BPMN -->
                    <div class="flex-1 bg-white border border-indigo-200 rounded-xl overflow-hidden shadow-sm flex flex-col"
                        x-data="{ done: false }">
                        <div class="bg-indigo-50 p-3 border-b border-indigo-100 flex items-center justify-between">
                            <span class="text-xs font-bold text-indigo-800 uppercase tracking-wider"><i
                                    class="fa-solid fa-diagram-project mr-1"></i> Integración BPMN / Workflow</span>
                        </div>
                        <div class="p-4 flex-1">
                            <p class="text-sm text-gray-700 font-medium mb-1">Crear Tarea: "Revisión informe financiero
                                Q3 y MSA"</p>
                            <p class="text-xs text-gray-500 mb-3">Asignar a: Grupo Legal • Vence: 28 Oct 2024</p>

                            <div class="flex justify-between items-center mt-auto" x-show="!done">
                                <button class="text-xs text-gray-500 hover:text-red-500 font-medium">Descartar</button>
                                <button @click="done = true"
                                    class="px-4 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-lg transition-colors shadow-sm">
                                    <i class="fa-solid fa-rocket mr-1"></i> Crear Tarea Operativa
                                </button>
                            </div>
                            <div x-show="done"
                                class="mt-4 flex items-center text-sm text-green-600 bg-green-50 p-2 rounded">
                                <i class="fa-solid fa-circle-check mr-2"></i> Tarea enviada al Inbox del equipo
                            </div>
                        </div>
                    </div>

                    <!-- Borrador de Respuesta -->
                    <div class="flex-1 bg-white border border-indigo-200 rounded-xl overflow-hidden shadow-sm flex flex-col"
