        dto.setCreatedAt(domain.getCreatedAt());
        dto.setCreatedBy(domain.getCreatedBy());

        if (dto.getPhases() != null) {
            for (int i = 0; i < dto.getPhases().size(); i++) {
                // Actualización menor por completitud
            }
        }

        return dto;
    }
}
