                </div>
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Chart 1 -->
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm">
