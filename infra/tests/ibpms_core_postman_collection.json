{
    "info": {
        "name": "iBPMS Core API - PoC",
        "description": "API Automation Collection for iBPMS Core based on OpenAPI definitions.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Authentication (Dummy)",
            "item": [
                {
                    "name": "Login (Mock)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Set dummy token for subsequent requests",
                                    "pm.environment.set(\"jwt_token\", \"dummy_jwt_token_for_tests\");",
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"test_user\",\n    \"password\": \"test_pass\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Cases (Expedientes)",
            "item": [
                {
                    "name": "Create Case",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 201\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData && jsonData.id) {",
                                    "    pm.environment.set(\"caseId\", jsonData.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "const { v4: uuidv4 } = require('uuid');",
                                    "pm.environment.set(\"idempotency_key\", uuidv4());"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{jwt_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idempotency_key}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"definitionKey\": \"prestamo-hipotecario\",\n  \"businessKey\": \"REQ-2026-001\",\n  \"variables\": {\n    \"clienteId\": 1001,\n    \"monto\": 150000\n  }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/cases",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "cases"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Case",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{jwt_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/cases/{{caseId}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "cases",
                                "{{caseId}}"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "3. Tasks (Tareas)",
            "item": [
                {
                    "name": "Get Tasks",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{jwt_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/tasks?limit=20&offset=0&status=PENDING",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "tasks"
                            ],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "20"
                                },
                                {
                                    "key": "offset",
                                    "value": "0"
                                },
                                {
                                    "key": "status",
                                    "value": "PENDING"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get Task Form",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{jwt_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/tasks/{{taskId}}/form",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "tasks",
                                "{{taskId}}",
                                "form"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Complete Task",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "const { v4: uuidv4 } = require('uuid');",
                                    "pm.environment.set(\"idempotency_key\", uuidv4());"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{jwt_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idempotency_key}}",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"variables\": {\n    \"aprobado\": true,\n    \"comentarios\": \"Todo conforme a las políticas del banco\"\n  }\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/tasks/{{taskId}}/complete",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "tasks",
                                "{{taskId}}",
                                "complete"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080/api/v1",
            "type": "string"
        },
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        },
        {
            "key": "caseId",
            "value": "",
            "type": "string"
        },
        {
            "key": "idempotency_key",
            "value": "",
            "type": "string"
        },
        {
            "key": "taskId",
            "value": "",
            "type": "string"
        }
    ]
}