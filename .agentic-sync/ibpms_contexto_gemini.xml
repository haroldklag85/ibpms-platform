    await new Promise(resolve => setTimeout(resolve, 1200));
    
    processHealth.value = {
      activeCases: 120,
      completedCases: 3400,
      activeTasks: 450,
      overdueTasks: 15
    };

    aiMetrics.value = {
      totalAiEvents: 2540,
