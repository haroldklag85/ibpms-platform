                                    class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center font-bold text-xs mr-3">
                                    1</div>
                                <img class="h-8 w-8 rounded-full mr-3"
                                    src="https://ui-avatars.com/api/?name=Maria&background=random" alt="" />
                                <div>
                                    <p class="text-sm font-bold text-gray-800">Maria S. (Analista Legal)</p>
                                    <p class="text-xs text-gray-500">45 Tareas cerradas (98% Eficiencia)</p>
                                </div>
                            </div>
                            <span
                                class="px-2 py-1 bg-green-50 text-green-700 text-xs font-bold rounded border border-green-200">#1</span>
                        </li>
                        <li class="flex items-center justify-between">
                            <div class="flex items-center">
                                <div
                                    class="w-8 h-8 rounded-full bg-gray-100 text-gray-700 flex items-center justify-center font-bold text-xs mr-3">
                                    2</div>
                                <img class="h-8 w-8 rounded-full mr-3"
                                    src="https://ui-avatars.com/api/?name=John&background=random" alt="" />
                                <div>
                                    <p class="text-sm font-bold text-gray-800">John D. (Especialista)</p>
                                    <p class="text-xs text-gray-500">38 Tareas cerradas (95% Eficiencia)</p>
                                </div>
                            </div>
                        </li>
                        <hr class="border-dashed border-gray-200">
                        <li class="flex items-center justify-between opacity-70">
                            <div class="flex items-center">
                                <div
                                    class="w-8 h-8 rounded-full bg-red-50 text-red-500 flex items-center justify-center font-bold text-xs mr-3">
                                    <i class="fa-solid fa-arrow-down"></i></div>
                                <img class="h-8 w-8 rounded-full mr-3 grayscale"
                                    src="https://ui-avatars.com/api/?name=Carlos&background=random" alt="" />
                                <div>
                                    <p class="text-sm font-bold text-gray-800">Carlos R. (Desarrollador Junior)</p>
                                    <p class="text-xs text-red-600">12 Cerradas (SLA roto en 5%)</p>
                                </div>
                            </div>
                            <span class="text-xs text-gray-400 font-medium">Bottom 10%</span>
