                                        </th>
                                        <th class="bg-gray-50"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-b border-gray-200 hover:bg-gray-50 group">
                                        <td
                                            class="border-r border-gray-300 text-center text-xs text-gray-400 font-mono">
                                            1</td>
                                        <td
                                            class="border-r border-gray-300 p-2 text-center text-sm font-mono text-blue-700">
