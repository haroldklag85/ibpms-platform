                </div>
                <!-- Chart 2 -->
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm">
                    <h3 class="text-sm font-bold text-gray-700 uppercase tracking-wider mb-4 border-b pb-2"><i
                            class="fa-solid fa-chart-line text-indigo-500 mr-2"></i> Tiempos de Resolución P50/P90</h3>
                    <div class="h-64 relative w-full">
                        <canvas id="lineChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Leaderboard & Bottlenecks -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                <!-- Performance Ranking -->
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm">
                    <h3
                        class="text-sm font-bold text-gray-700 uppercase tracking-wider mb-4 border-b pb-2 flex justify-between">
                        <span><i class="fa-solid fa-users text-emerald-500 mr-2"></i> Desempeño del Equipo</span>
                        <a href="#" class="text-xs text-blue-500 hover:underline normal-case">Descargar CSV</a>
                    </h3>

                    <ul class="space-y-4">
                        <li class="flex items-center justify-between">
                            <div class="flex items-center">
