                        <p class="text-2xl font-bold text-gray-900">4,912</p>
                    </div>
                </div>
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center">
                    <div
                        class="w-12 h-12 bg-orange-50 text-orange-600 rounded-lg flex items-center justify-center text-xl mr-4">
                        <i class="fa-regular fa-clock"></i></div>
                    <div>
