            </div>
        </header>

        <main class="p-6 max-w-7xl mx-auto w-full space-y-6">

            <!-- Global KPIs -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center">
                    <div
