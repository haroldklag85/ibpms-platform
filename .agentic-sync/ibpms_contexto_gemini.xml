                </button>
            </div>
        </header>

        <!-- Main Layout -->
        <div class="flex-1 flex overflow-hidden p-6 gap-6">

            <!-- Panel Izquierdo: Chat IA -->
            <div
                class="w-1/3 flex flex-col bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden shrink-0">
